<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://example.com/bpmn">

  <process id="CustomerPurchaseJourney" name="Customer Purchase Journey" isExecutable="false">

    <!-- Start Event -->
    <startEvent id="StartEvent" name="Start Browsing"/>

    <!-- Tasks -->
    <task id="BrowseProducts" name="Browse Products"/>
    <task id="AddToCart" name="Add to Cart"/>
    <task id="Checkout" name="Proceed to Checkout"/>
    <task id="EnterDetails" name="Enter Shipping Details"/>
    <task id="ConfirmOrder" name="Confirm Order"/>
    <task id="LockInventory" name="Lock Inventory"/>
    <task id="SendPaymentRequest" name="Send Payment Request"/>
    <task id="ProcessPayment" name="Process Payment"/>
    <task id="CreateOrder" name="Create Order"/>
    <task id="ReleaseInventory" name="Release Inventory"/>
    <task id="SendConfirmation" name="Send Confirmation"/>

    <!-- Gateway -->
    <exclusiveGateway id="PaymentGatewayDecision" name="Payment Successful?"/>

    <!-- End Events -->
    <endEvent id="EndSuccess" name="Order Completed"/>
    <endEvent id="EndFailure" name="Payment Failed"/>

    <!-- Sequence Flows -->
    <sequenceFlow id="flow1" sourceRef="StartEvent" targetRef="BrowseProducts"/>
    <sequenceFlow id="flow2" sourceRef="BrowseProducts" targetRef="AddToCart"/>
    <sequenceFlow id="flow3" sourceRef="AddToCart" targetRef="Checkout"/>
    <sequenceFlow id="flow4" sourceRef="Checkout" targetRef="EnterDetails"/>
    <sequenceFlow id="flow5" sourceRef="EnterDetails" targetRef="ConfirmOrder"/>
    <sequenceFlow id="flow6" sourceRef="ConfirmOrder" targetRef="LockInventory"/>
    <sequenceFlow id="flow7" sourceRef="LockInventory" targetRef="SendPaymentRequest"/>
    <sequenceFlow id="flow8" sourceRef="SendPaymentRequest" targetRef="ProcessPayment"/>
    <sequenceFlow id="flow9" sourceRef="ProcessPayment" targetRef="PaymentGatewayDecision"/>

    <sequenceFlow id="flow10" sourceRef="PaymentGatewayDecision" targetRef="CreateOrder">
      <conditionExpression xsi:type="tFormalExpression">success</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow11" sourceRef="PaymentGatewayDecision" targetRef="ReleaseInventory">
      <conditionExpression xsi:type="tFormalExpression">failure</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow12" sourceRef="CreateOrder" targetRef="SendConfirmation"/>
    <sequenceFlow id="flow13" sourceRef="SendConfirmation" targetRef="EndSuccess"/>
    <sequenceFlow id="flow14" sourceRef="ReleaseInventory" targetRef="EndFailure"/>

  </process>

</definitions>
